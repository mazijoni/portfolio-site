rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin — full read/write access to everything
    match /{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.email == "maze.development.admin@gmail.com";
    }

    // Own data — full access
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared project read access for members; contributors may update notes
    match /users/{ownerUid}/projects/{pid} {
      allow read: if request.auth != null &&
                     resource.data.members[request.auth.uid] != null;
      allow update: if request.auth != null &&
                       resource.data.members[request.auth.uid].role == "contributor" &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notes']);
    }
    match /users/{ownerUid}/projects/{pid}/{sub}/{docId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(ownerUid)/projects/$(pid))
          .data.members[request.auth.uid] != null;
      allow write: if request.auth != null &&
      	get(/databases/$(database)/documents/users/$(ownerUid)/projects/$(pid))
        	.data.members[request.auth.uid].rule == "contributor"
    }

    // Memberships — written by owner when sharing, read by the member
    match /users/{userId}/memberships/{mid} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

    // Public profiles — any signed-in user can read (needed for the share picker)
    match /user_profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Eurovision shared scoring rooms — any signed-in user can read/write
    match /esc_rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Eurovision personal ballots — only the owner can read/write
    match /esc_users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public games — anyone can read, admin only can write the game doc
    match /public_games/{gameId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "maze.development.admin@gmail.com";
    }

    // Game ratings — anyone can read; each authenticated user writes only their own doc
    match /public_games/{gameId}/ratings/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Game comments — anyone can read; authenticated users can create (must set uid = their own);
    // owner or admin can delete
    match /public_games/{gameId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && (
        request.auth.token.email == "maze.development.admin@gmail.com" ||
        resource.data.uid == request.auth.uid
      );
    }

    // Site analytics — anyone can write (visit tracking), admin-only read
    match /site_analytics/{docId} {
      allow create: if true;
      allow read: if request.auth != null
                  && request.auth.token.email == "maze.development.admin@gmail.com";
    }

    // Global service config — all signed-in users can read, admin-only write
    match /admin/serviceConfig {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email == "maze.development.admin@gmail.com";
    }
  }
}
